class Solution {
    public double myPow(double x, int n) {
       if(n==0) return 1.0;
       if(x==0) return 0.0;
       if(x==-1 && n%2==0) return 1.0;
       if(x==-1 && n%2!=0) return -1.0;
        long binf=n;
        double ans=1;
        if(binf<0){
            x=1/x;
            binf= -binf;
        }
        while(binf>0){
            if(binf%2==1){
               ans*=x;
            }
            x*=x;
            binf/=2;

        }
        return ans;

    }
}
